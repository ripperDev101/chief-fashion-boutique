# Supabase (publishable values — safe in client bundle)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Ozow payments
# WARNING: the secret key currently ships in the client bundle (see README security notes).
# Rotate it via the Ozow merchant dashboard if it is ever exposed.
VITE_OZOW_SITE_CODE="your-ozow-site-code"
VITE_OZOW_SECRET_KEY="your-ozow-secret-key"
VITE_OZOW_IS_TEST="true"
VITE_OZOW_TEST_AMOUNT="0.01"
