# Supabase (publishable values — safe in client bundle)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Ozow credentials are NOT set here. They live server-side as Supabase Edge
# Function secrets (never in the client bundle):
#   npx supabase secrets set OZOW_SITE_CODE=... OZOW_PRIVATE_KEY=... \
#     OZOW_IS_TEST=true OZOW_TEST_AMOUNT=0.01 --project-ref <ref>
